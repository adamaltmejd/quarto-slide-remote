{
  "name": "quarto-slide-remote",
  "version": "0.5.1",
  "private": true,
  "description": "iPhone remote control + speaker-notes companion for static reveal.js decks",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:plugin": "bun packages/deck-plugin/build.ts",
    "build:plugin:min": "bun packages/deck-plugin/build.ts --minify",
    "build:phone": "bun packages/phone-ui/build.ts",
    "dev:plugin": "bun packages/deck-plugin/build.ts --watch",
    "dev:phone": "bun packages/phone-ui/build.ts --watch",
    "dev:worker": "cd packages/worker && bunx wrangler dev",
    "dev:install": "bun scripts/dev-install.ts --watch",
    "demo": "bun scripts/demo.ts",
    "deploy": "bun run build:plugin:min && bun run build:phone && cd packages/worker && bunx wrangler deploy",
    "typecheck": "tsc --noEmit -p packages/protocol && tsc --noEmit -p packages/deck-plugin && tsc --noEmit -p packages/phone-ui && tsc --noEmit -p packages/worker",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test",
    "test:smoke": "SR_INTEGRATION=1 bun test packages/worker/test/integration.test.ts",
    "size": "bun scripts/size-check.ts",
    "check:bundle": "bun scripts/check-bundle-fresh.ts",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "^1.3.12",
    "happy-dom": "20.9.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.83.0"
  }
}
